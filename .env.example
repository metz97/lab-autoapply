# --- Supabase (required for auth, dashboard, and the REST API) ---
# Project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Public anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key (server-only — never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (optional: distributed rate limiting for the extension API) ---
# If unset, rate limiting is disabled (all requests allowed).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Portfolio backlink (optional) ---
# URL used by the "Back to portfolio" link. Falls back to "#" when unset.
NEXT_PUBLIC_PORTFOLIO_URL=

# --- Extension rate-limit tuning (optional; only used when Upstash is configured) ---
# Max requests per window per user, and the window length in ms.
# AUTOAPPLY_EXTENSION_RATE_LIMIT_MAX=120
# AUTOAPPLY_EXTENSION_RATE_LIMIT_WINDOW_MS=3600000
